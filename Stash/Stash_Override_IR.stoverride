Name: Stash Iran Override
category: Active

desc: |-
  [English]
  DNS | Proxy Groups | Rules
  Version: 1.0 | 2026-07-08
  Encrypted DNS: DoH(DoT) | IPv6 | IPv4
  Policy Groups: IR-Gate {IR-Auto/Global/DE/FI/TR/AE}
  Rules: Fully Optimized for Iran Users (Anti-Filter & Localization)
  MATCH -> IR-Gate (Default Fallback)

  [فارسی - توضیح]
  📌 محیط برنامه: مناسب برای کاربران داخل ایران در برنامه Stash (آیفون/آیپد).
  ⚙️ پیکربندی اصلی: شامل تنظیمات دی‌ان‌اس رمزگذاری‌شده، گروه‌های پروکسی با تست سرعت خودکار و قوانین تفکیک ترافیک.
  
  📦 راهنمای گروه‌های پروکسی:
   - [گروه اصلی IR-Gate]: شامل گروه‌های IR-Auto، آلمان، فنلاند، ترکیه، امارات و اتصال مستقیم (DIRECT).
   - [گروه هوشمند IR-Auto]: این گروه به صورت خودکار سرعت بهترین سرورهای نزدیک به ایران (اروپا و خاورمیانه) را بررسی کرده و سریع‌ترین را انتخاب می‌کند.
     💡 نکته: کافیست در گروه اصلی IR-Gate گزینه IR-Auto را انتخاب کنید و نیازی به انتخاب دستی سرورها نیست.
   - [اتصال مستقیم DIRECT]: برای وب‌سایت‌های ایرانی، بانک‌ها و خدمات دولتی که آی‌پای خارجی را مسدود می‌کنند، به صورت خودکار فعال است.
  
  ⚡ قوانین تفکیک ترافیک:
   - خدمات ایرانی: تمام سایت‌های ترافیک داخلی ایران (.ir) و برنامه‌های بومی مستقیماً بدون پروکسی باز می‌شوند تا اینترنت نیم‌بها محاسبه شود و خدمات بانکی قطع نشوند.
   - برنامه‌های بین‌المللی: دسترسی به سرویس‌های هوش مصنوعی (ChatGPT و غیره)، گوگل، یوتیوب، تلگرام، اینستاگرام و واتس‌اپ از طریق پروکسی بهینه‌سازی شده است.

#!override

mixed-port: 7890
allow-lan: true
bind-address: '*'
mode: rule
log-level: info
external-controller: ':9090'
unified-delay: true
tcp-concurrent: true

dns: #!replace
  enable: true
  respect-rules: true
  ipv6: true
  prefer-h3: true
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16

  # DNS اولیه برای رزولوشن داخلی (جهت حل مشکل دامنه‌های فیلتر شده و خدمات محلی)
  default-nameserver:
    - 1.1.1.1
    - 9.9.9.9
    - 178.22.122.100 # دی‌ان‌اس شکن برای دور زدن برخی تحریم‌های خارجی علیه ایران

  # دی‌ان‌اس‌های رمزگذاری‌شده از راه دور جهت جلوگیری از جعل و آلودگی دی‌ان‌اس توسط سیستم فیلترینگ
  nameserver:
    - https://dns.cloudflare.com/dns-query
    - https://dns.google/dns-query
    - https://dns.quad9.net/dns-query

  proxy-server-nameserver:
    - https://dns.cloudflare.com/dns-query
    - https://dns.google/dns-query
    - https://1.1.1.1/dns-query
    - https://8.8.8.8/dns-query
    - tls://1.1.1.1:853
    - tls://8.8.8.8:853

  direct-nameserver:
    - https://1.1.1.1/dns-query
    - https://9.9.9.9/dns-query

  # بهینه‌سازی دی‌ان‌اس برای خدمات داخلی، اپلیکیشن‌های محبوب و درگاه‌های بانکی ایران
  nameserver-policy:
    '+.ir': [178.22.122.100, 1.1.1.1] # مدیریت تمام دامنه‌های ir.
    '+.snapp.ir': [178.22.122.100]    # اسنپ
    '+.tapsi.ir': [178.22.122.100]    # تپسی
    '+.digikala.com': [1.1.1.1]       # دیجی‌کالا
    '+.divar.ir': [178.22.122.100]    # دیوار
    '+.bamilo.com': [1.1.1.1]
    '+.aparat.com': [1.1.1.1]         # آپارات
    '+.filimo.com': [1.1.1.1]         # فیلیمو
    '+.cafebazaar.ir': [178.22.122.100] # کافه بازار
    '+.myket.ir': [178.22.122.100]     # مایکت
    # پیام‌رسان‌ها و شبکه‌های اجتماعی داخلی
    '+.rubika.ir': [178.22.122.100]   # روبیکا
    '+.bale.ai': [1.1.1.1]             # بله
    '+.gap.im': [1.1.1.1]              # گپ
    '+.soroush-app.ir': [178.22.122.100]
    # بانک‌ها و درگاه‌های پرداخت اصلی ایران
    '+.bmi.ir': [178.22.122.100]      # بانک ملی
    '+.banksepah.ir': [178.22.122.100] # بانک سپه
    '+.bsi.ir': [178.22.122.100]       # بانک صادرات
    '+.tejaratbank.ir': [178.22.122.100] # بانک تجارت
    '+.mellatbank.ir': [178.22.122.100]  # بانک ملت
    '+.sb24.com': [1.1.1.1]            # بانک سامان
    '+.parsian-bank.ir': [178.22.122.100] # بانک پارسیان

  fallback:
    - https://dns.cloudflare.com/dns-query
    - https://dns.google/dns-query

  fallback-filter:
    geoip: true
    geoip-code: IR # فیلتر ژئوای‌پی مخصوص ایران
    ipcidr:
      - 240.0.0.0/4

  fake-ip-filter:
    - '*.lan'
    - '*.local'
    - 'localhost'
    - '*.msftconnecttest.com'
    - '*.msftncsi.com'
    - 'captive.apple.com'
    - 'stun.*'
    - '+.stun.*.*'
    - '+.stun.*.*.*'
    - '+.stun.*.*.*.*'
    - '+.stun.*.*.*.*.*'
    - 'speedtest.net'
    - '+.ir'

profile: #!replace
  store-selected: true
  store-fake-ip: true

#---------------------------------------------------#
# تنظیمات گروه‌های پروکسی (Proxy Groups)             #
#---------------------------------------------------#
proxy-groups: #!replace
  # دروازه اصلی کنترل ترافیک (هدایت پیش‌فرض به گروه تست سرعت هوشمند)
  - name: IR-Gate
    type: select
    icon: https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Final.png
    proxies:
      - 🚀 IR-Auto       # تست سرعت هوشمند بین سرورهای بهینه (پیشنهادی)
      - 🌐 Global-Proxy  # انتخاب دستی تمامی سرورها
      - 🇩🇪 DE-Auto       # تست سرعت خودکار سرورهای آلمان
      - 🇫🇮 FI-Auto       # تست سرعت خودکار سرورهای فنلاند
      - 🇹🇷 TR-Auto       # تست سرعت خودکار سرورهای ترکیه (تاخیر کم)
      - 🇦🇪 AE-Auto       # تست سرعت خودکار سرورهای امارات
      - DIRECT            # اتصال مستقیم (صرفاً برای ترافیک داخلی ایران)

  # گروه تست سرعت خودکار (انتخاب سریع‌ترین سرور خاورمیانه و اروپا با بازه زمانی ۵ دقیقه جهت پایداری بالا)
  - name: 🚀 IR-Auto
    type: url-test
    include-all: true
    icon: https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Rocket.png
    filter: '(?i)(\[DE\]|Germany|德国|\[FI\]|Finland|芬兰|\[TR\]|Turkey|土耳其|\[AE\]|UAE|阿联酋)'
    url: http://www.gstatic.com/generate_204
    interval: 300
    tolerance: 50

  - name: 🌐 Global-Proxy
    type: select
    include-all: true
    icon: https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Global.png

  - name: 🇩🇪 DE-Auto
    type: url-test
    include-all: true
    icon: https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Germany.png
    filter: '(?i)(\[DE\]|^DE$|Germany|Deutschland|\bDE\b|德国|法兰ک福)'
    url: http://www.gstatic.com/generate_204
    interval: 600
    tolerance: 50

  - name: 🇫🇮 FI-Auto
    type: url-test
    include-all: true
    icon: https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Finland.png
    filter: '(?i)(\[FI\]|^FI$|Finland|Suomi|\bFI\b|芬兰|赫尔辛基)'
    url: http://www.gstatic.com/generate_204
    interval: 600
    tolerance: 50

  - name: 🇹🇷 TR-Auto
    type: url-test
    include-all: true
    icon: https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/Turkey.png
    filter: '(?i)(\[TR\]|^TR$|Turkey|Türkiye|\bTR\b|土耳其|伊斯坦布尔)'
    url: http://www.gstatic.com/generate_204
    interval: 600
    tolerance: 50

  - name: 🇦🇪 AE-Auto
    type: url-test
    include-all: true
    icon: https://fastly.jsdelivr.net/gh/Koolson/Qure/IconSet/Color/United_Arab_Emirates.png
    filter: '(?i)(\[AE\]|^AE$|UAE|Emirates|\bAE\b|阿联酋|迪拜)'
    url: http://www.gstatic.com/generate_204
    interval: 600
    tolerance: 50

rules: #!replace

  # GitHub
  - DOMAIN-SUFFIX,github.com,IR-Gate
  - DOMAIN-SUFFIX,githubusercontent.com,IR-Gate
  - DOMAIN-SUFFIX,githubassets.com,IR-Gate
  - DOMAIN-SUFFIX,raw.githubusercontent.com,IR-Gate

  # شبکه محلی (LAN)
  - IP-CIDR,192.168.0.0/16,DIRECT,no-resolve
  - IP-CIDR,10.0.0.0/8,DIRECT,no-resolve
  - IP-CIDR,172.16.0.0/12,DIRECT,no-resolve
  - IP-CIDR,127.0.0.0/8,DIRECT,no-resolve
  - GEOIP,LAN,DIRECT,no-resolve

  # ========= خدمات داخلی ایران (اتصال مستقیم) =========
  # هدایت مستقیم ترافیک وب‌سایت‌ها و اپلیکیشن‌های ایرانی برای جلوگیری از مسدود شدن آی‌پای خارجی
  - DOMAIN-SUFFIX,ir,DIRECT
  - DOMAIN-KEYWORD,snapp,DIRECT
  - DOMAIN-KEYWORD,tapsi,DIRECT
  - DOMAIN-KEYWORD,digikala,DIRECT
  - DOMAIN-KEYWORD,divar,DIRECT
  - DOMAIN-KEYWORD,bazaar,DIRECT
  - DOMAIN-KEYWORD,myket,DIRECT
  - DOMAIN-KEYWORD,rubika,DIRECT
  - DOMAIN-KEYWORD,bale,DIRECT

  # ========= قوانین سفارشی (نیازمند پروکسی) =========

  # سرویس‌های هوش مصنوعی جهانی (ChatGPT, Claude, Gemini, Copilot)
  - DOMAIN-KEYWORD,openai,IR-Gate
  - DOMAIN-KEYWORD,chatgpt,IR-Gate
  - DOMAIN-SUFFIX,auth0.com,IR-Gate
  - DOMAIN-SUFFIX,identrust.com,IR-Gate
  - DOMAIN-SUFFIX,oaistatic.com,IR-Gate
  - DOMAIN-SUFFIX,oaiusercontent.com,IR-Gate
  - DOMAIN-SUFFIX,anthropic.com,IR-Gate
  - DOMAIN-SUFFIX,claude.ai,IR-Gate
  - DOMAIN-SUFFIX,deepmind.com,IR-Gate
  - DOMAIN-SUFFIX,gemini.google.com,IR-Gate
  - DOMAIN-KEYWORD,copilot,IR-Gate
  - DOMAIN-SUFFIX,designer.microsoft.com,IR-Gate
  - DOMAIN-SUFFIX,copilot.microsoft.com,IR-Gate
  - DOMAIN-SUFFIX,ai.microsoft.com,IR-Gate

  # مایکروسافت وان‌درایو (نسخه وب)
  - DOMAIN,onedrive.live.com,IR-Gate
  - DOMAIN-SUFFIX,1drv.com,IR-Gate

  # گوگل و یوتیوب
  - DOMAIN-KEYWORD,google,IR-Gate
  - DOMAIN-SUFFIX,gmail.com,IR-Gate
  - DOMAIN-SUFFIX,googlevideo.com,IR-Gate
  - DOMAIN-SUFFIX,youtube.com,IR-Gate
  - DOMAIN-SUFFIX,ytimg.com,IR-Gate
  - DOMAIN-SUFFIX,ggpht.com,IR-Gate

  # تلگرام
  - DOMAIN-SUFFIX,telegram.org,IR-Gate
  - DOMAIN-SUFFIX,telegram.me,IR-Gate
  - DOMAIN-SUFFIX,t.me,IR-Gate
  - DOMAIN-SUFFIX,tdesktop.com,IR-Gate
  - IP-CIDR,91.108.4.0/22,IR-Gate,no-resolve
  - IP-CIDR,91.108.8.0/22,IR-Gate,no-resolve
  - IP-CIDR,91.108.12.0/22,IR-Gate,no-resolve
  - IP-CIDR,91.108.16.0/22,IR-Gate,no-resolve
  - IP-CIDR,91.108.20.0/22,IR-Gate,no-resolve
  - IP-CIDR,91.108.56.0/22,IR-Gate,no-resolve
  - IP-CIDR,149.154.160.0/20,IR-Gate,no-resolve
  - IP-CIDR6,2001:b28:f23d::/48,IR-Gate,no-resolve
  - IP-CIDR6,2001:b28:f23f::/48,IR-Gate,no-resolve
  - IP-CIDR6,2001:67c:4e8::/48,IR-Gate,no-resolve

  # متا (اینستاگرام و واتس‌اپ) - شبکه‌های اجتماعی پرکاربرد و فیلتر شده در ایران
  - DOMAIN-KEYWORD,instagram,IR-Gate
  - DOMAIN-SUFFIX,cdninstagram.com,IR-Gate
  - DOMAIN-KEYWORD,whatsapp,IR-Gate
  - DOMAIN-SUFFIX,whatsapp.net,IR-Gate

  # ========= پایان قوانین سفارشی =========

  # مجموعه‌های قانون راه دور مخصوص ایران (لیست دامنه‌ها و آی‌پیدرهای داخلی)
  - RULE-SET,IranMax,DIRECT
  - RULE-SET,IranIP,DIRECT,no-resolve

  # مسدودسازی تبلیغات جهانی و حفاظت از حریم خصوصی
  - RULE-SET,AdvertisingLite,REJECT
  - RULE-SET,Privacy,REJECT

  # استراتژی نهایی مسیریابی ترافیک (از پایین به بالا)
  - GEOIP,LAN,DIRECT
  - GEOIP,IR,DIRECT,no-resolve # اتصال مستقیم پیش‌فرض برای آی‌پپ‌های ایران
  - MATCH,IR-Gate # هدایت تمامی ترافیک باقی‌مانده و تطبیق‌نیافته به پروکسی خارج از کشور

rule-providers: #!replace

  IranIP:
    behavior: ipcidr
    format: text
    interval: 86400
    url: https://raw.githubusercontent.com/vfarid/iran-ip-cidr/main/iran_ip_cidr.txt

  IranMax:
    behavior: domain
    format: text
    interval: 86400
    url: https://raw.githubusercontent.com/bootmortis/iran-hosted-domains/master/String.txt

  AdvertisingLite:
    behavior: domain
    format: yaml
    interval: 86400
    url: https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/AdvertisingLite/AdvertisingLite_Domain.yaml

  Privacy:
    behavior: domain
    format: yaml
    interval: 86400
    url: https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/Privacy/Privacy_Domain.yaml
